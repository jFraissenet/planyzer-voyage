  "about": {
    "title": "Planyzer",
    "tagline": "Plan your events, together.",
    "description": "A dinner, a weekend away, a trip with friends… and suddenly you're juggling Splitwise, a Doodle, Google Docs, a recipe site and three carpool apps. Planyzer brings it all under one roof: create the event, invite your people, add the tools you actually need. One app, zero chaos.",
    "feature1Title": "Events",
    "feature1Body": "One page per outing, with its dates and participants.",
    "feature2Title": "Modular tools",
    "feature2Body": "Add whatever you need along the way: schedule, teams, polls, meals, money, notes, carpool.",
    "feature3Title": "Controlled sharing",
    "feature3Body": "Some tools visible to everyone, others reserved for a subgroup.",
    "toolsSection": "The tools",
    "tools": {
      "money": {
        "title": "Money",
        "body": "Split expenses with your group and see who owes what to whom — no calculator needed."
      },
      "notes": {
        "title": "Notes",
        "body": "Jot down everything on your mind and check off what's done, to stay on top of things before the big day."
      },
      "car_sharing": {
        "title": "Carpool",
        "body": "Plan rides together: who goes with whom, at what time, and how many seats are left."
      },
      "proposals": {
        "title": "Poll",
        "body": "Run a poll or idea board: suggest options, collect votes, and decide together."
      },
      "meals": {
        "title": "Meals",
        "body": "Save your trip's recipes, list their ingredients, and let the shopping list build itself."
      },
      "planning": {
        "title": "Schedule",
        "body": "The trip's calendar: add moments and link them to meals, rides, or people."
      },
      "teams": {
        "title": "Teams",
        "body": "Create groups of people — cooking, washing-up, tournament team… — reusable across your schedules."
      }
    }
  },
