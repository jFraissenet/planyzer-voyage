  "about": {
    "title": "Planyzer",
    "tagline": "Organiza tus eventos, en equipo.",
    "description": "Una cena, un finde, un viaje entre amigos… y acabas saltando entre Splitwise, un Doodle, Google Docs, un sitio de recetas y tres apps de coche compartido. Planyzer lo reúne todo en un mismo sitio: creas el evento, invitas a los tuyos, añades las herramientas que de verdad necesitas. Una sola app, cero jaleo.",
    "feature1Title": "Eventos",
    "feature1Body": "Una página por salida, con sus fechas y participantes.",
    "feature2Title": "Herramientas modulares",
    "feature2Body": "Añade sobre la marcha lo que necesitéis: agenda, equipos, encuestas, comidas, dinero, notas, coche compartido.",
    "feature3Title": "Compartir a medida",
    "feature3Body": "Algunas herramientas para todos, otras reservadas a un subgrupo.",
    "toolsSection": "Las herramientas",
    "tools": {
      "money": {
        "title": "Dinero",
        "body": "Reparte los gastos con tu grupo y mira quién le debe qué a quién, sin sacar la calculadora."
      },
      "notes": {
        "title": "Notas",
        "body": "Apunta todo lo que te preocupa y marca lo que ya has hecho, para llegar tranquilo al día señalado."
      },
      "car_sharing": {
        "title": "Compartir coche",
        "body": "Organizad los trayectos juntos: quién va con quién, a qué hora y cuántas plazas quedan libres."
      },
      "proposals": {
        "title": "Encuesta",
        "body": "Lanza una encuesta o un tablero de ideas: proponed opciones, recoged votos y decidid juntos."
      },
      "meals": {
        "title": "Comidas",
        "body": "Guarda las recetas del viaje y sus ingredientes: la lista de la compra se monta sola."
      },
      "planning": {
        "title": "Agenda",
        "body": "El calendario del viaje: añade momentos y vincúlalos con las comidas, los trayectos o las personas."
      },
      "teams": {
        "title": "Equipos",
        "body": "Crea grupos de personas — cocina, fregado, equipo del torneo… — reutilizables en tus agendas."
      }
    }
